import numpy as np

# scipy is optional — a lightweight shim is provided for environments without it.
try:
    from scipy import stats as _scipy_stats
    _TRUNCNORM = _scipy_stats.truncnorm
    _T_PPF     = _scipy_stats.t.ppf
except ModuleNotFoundError:
    from math import sqrt as _sqrt

    class _TruncNormShim:
        @staticmethod
        def rvs(a, b, loc, scale, size, random_state):
            """Rejection-sampling truncated normal fallback."""
            rng = np.random.default_rng(random_state)
            out = []
            upper = b if b < np.inf else 1e9
            while len(out) < size:
                s = rng.normal(0.0, 1.0, size * 4)
                s = s[(s >= a) & (s <= upper)]
                out.extend(s.tolist())
            return np.array(out[:size]) * scale + loc

    _T_TABLE = {
        1: 12.706, 2: 4.303,  3: 3.182,  4: 2.776,  5: 2.571,
        6: 2.447,  7: 2.365,  8: 2.306,  9: 2.262, 10: 2.228,
        11: 2.201, 12: 2.179, 13: 2.160, 14: 2.145, 15: 2.131,
        16: 2.120, 17: 2.110, 18: 2.101, 19: 2.093, 20: 2.086,
        21: 2.080, 22: 2.074, 23: 2.069, 24: 2.064, 25: 2.060,
        26: 2.056, 27: 2.052, 28: 2.048, 29: 2.045, 30: 2.042,
    }

    def _t_ppf_shim(q, df):
        return _T_TABLE.get(int(df), 1.96 + 1.14 / df)

    _TRUNCNORM = _TruncNormShim()
    _T_PPF     = _t_ppf_shim


