@dataclass
class EmissionParams:
    """
    Observed Belchatow emission record from 30 quantification-supporting overpasses.

    Source: combined MBSP 2019-2020 (sc_cfar > tau=3.5796) and production-rule-audit
    annual timeseries 2021-2024. Mine centroid crop 51.242N, 19.275E.
    The 95% CI is the t-distribution sampling CI on the mean flow rate (df=29),
    propagated to t/yr via upper-framing annualisation.

    Attributes
    ----------
    mean_flow_kgh : float
        Mean per-overpass flow rate in kg CH4/hr.
    sd_flow_kgh : float
        Standard deviation across 30 detections in kg/hr.
    n_obs : int
        Number of quantification-supporting observations.
    mean_annual_t : float
        Detection-weighted annualised estimate in t CH4/yr.
    ci95_lo : float
        95% CI lower bound in t/yr.
    ci95_hi : float
        95% CI upper bound in t/yr.
    hours_per_year : float
        Hours per year for mean-flow annualisation.
    """
    mean_flow_kgh:  float =   476.0
    sd_flow_kgh:    float =   363.0
    n_obs:          int   =    30
    mean_annual_t:  float = 4_174.0
    ci95_lo:        float = 2_987.0
    ci95_hi:        float = 5_360.0
    hours_per_year: float = 8_760.0


@dataclass
class UncertaintyParams:
    """
    Uncertainty sources following the NIST IR 8575 IME/CEMF uncertainty budget.

    Per-overpass wind (+-20%) and retrieval coefficient (+-15%) uncertainties are
    already absorbed by the 30-observation t-distribution sampling CI. The layers
    here capture SYSTEMATIC annual-level uncertainties not present in that CI.

    Attributes
    ----------
    wind_sigma_systematic : float
        1-sigma relative systematic ERA5 bias (grid-to-point interpolation).
    mask_jitter_lo : float
        Lower bound of the plume-mask spatial extent multiplier.
    mask_jitter_hi : float
        Upper bound of the plume-mask spatial extent multiplier.
    retrieval_sigma : float
        IME coefficient precision sigma; set to 0.0 to disable (already in CI).
    tau_current : float
        Production conformal detection threshold.
    tau_boot_mean : float
        Bootstrap mean of tau over 2,000 resamples.
    tau_boot_std : float
        Bootstrap standard deviation of tau.
    base_det_rate : float
        Base detection rate at tau_current (31 detections / 123 valid observations).
    """
    wind_sigma_systematic: float = 0.10
    mask_jitter_lo:        float = 0.85
    mask_jitter_hi:        float = 1.15
    retrieval_sigma:       float = 0.0
    tau_current:           float = 3.5796
    tau_boot_mean:         float = 3.3406
    tau_boot_std:          float = 0.7056
    base_det_rate:         float = 0.252


@dataclass
class CarbonPriceParams:
    """
    Carbon price distribution and GWP conversion factors.

    Price model: log-normal with central scenario EUR 70/tCO2e, 30% log-vol.
    Consistent with Amundi (2024) who model EUA price as a GBM with drift and
    volatility drawn from historical EU ETS data.

    Pass-through model: Beta(9, 1) -> mean 0.90. Conservative stress scenario
    where EU Methane Regulation (2024/1787) enforcement is assumed highly likely.

    Attributes
    ----------
    central : float
        Central EUA price scenario in EUR/tCO2e.
    log_vol : float
        Log-normal volatility of the carbon price draw.
    gwp100 : int
        GWP100 conversion factor (IPCC AR5, EU MRV regulatory metric).
    gwp20 : int
        GWP20 conversion factor (IPCC AR6, near-term investor horizon).
    passthrough_alpha : float
        Alpha parameter of the Beta enforcement pass-through distribution.
    passthrough_beta : float
        Beta parameter of the Beta enforcement pass-through distribution.
    """
    central:           float = 70.0
    log_vol:           float = 0.30
    gwp100:            int   = GWP100_FACTOR
    gwp20:             int   = GWP20_FACTOR
    passthrough_alpha: float = 9.0
    passthrough_beta:  float = 1.0


# ---------------------------------------------------------------------------
# Base uncertainty layer
# ---------------------------------------------------------------------------

class BaseUncertaintyLayer(ABC):
    """
    Abstract base class for all Monte Carlo uncertainty layers.

    Each layer draws n_sim independent samples representing one source of
    uncertainty (emission quantity, wind bias, price, etc.).  The ClimateVarEngine
    multiplies these draws together to form the joint liability distribution.

    Subclasses must implement Sample() and Describe().
    """

    @abstractmethod
    def Sample(self, n_sim: int, rng: np.random.Generator) -> np.ndarray:
        """
        Draw n_sim independent samples from this uncertainty layer.

        Parameters
        ----------
        n_sim : int
            Number of Monte Carlo paths to draw.
        rng : np.random.Generator
            Seeded NumPy random generator for reproducibility.

        Return
        ------
        np.ndarray of shape (n_sim,) representing per-path multipliers or values.
        """

    @abstractmethod
    def Describe(self) -> dict:
        """
        Return a dict summarising the layer's parameters for audit output.

        Return
        ------
        dict with string keys describing the layer configuration.
        """


# ---------------------------------------------------------------------------
# Concrete uncertainty layers
# ---------------------------------------------------------------------------

class EmissionSamplingLayer(BaseUncertaintyLayer):
    """
    Layer 1: Annual emission sampling uncertainty modelled as a truncated normal.

    The sampling standard error of the mean is derived from the 95% CI via the
    t-distribution (df = n_obs - 1). The distribution is truncated at zero to
    prevent unphysical negative emission draws. At 4,174 t/yr with SEM ~ 580 t/yr,
    the zero bound lies ~7.2 sigma below the mean; truncation shifts E[Q] by less
    than 1e-12 sigma, so the accounting property E[Liability] = mean_annual_t x ...
    holds to an excellent approximation.

    References
    ----------
    NIST IR 8575 (Worden et al. 2025), Section 4.2 uncertainty budget.
    """

    def __init__(self, params: EmissionParams):
        """
        Parameters
        ----------
        params : EmissionParams
            Emission record dataclass with mean, CI bounds, and observation count.
        """
        self._params = params
        t_crit = float(_T_PPF(0.975, df=params.n_obs - 1))
        self._sem = (params.ci95_hi - params.ci95_lo) / (2.0 * t_crit)
        self._a   = (0.0 - params.mean_annual_t) / self._sem   # standardised zero bound

    def Sample(self, n_sim: int, rng: np.random.Generator) -> np.ndarray:
        """
        Draw n_sim annual emission quantities (t CH4/yr) from the truncated normal.

        Parameters
        ----------
        n_sim : int
            Number of simulation paths.
        rng : np.random.Generator
            Seeded NumPy random generator.

        Return
        ------
        np.ndarray of shape (n_sim,) in units of t CH4/yr.
        """
        seed_val = int(rng.integers(0, 2**31))
        return _TRUNCNORM.rvs(
            self._a, np.inf,
            loc=self._params.mean_annual_t,
            scale=self._sem,
            size=n_sim,
            random_state=seed_val,
        )

    def Describe(self) -> dict:
        """
        Return
        ------
        dict with mean, CI bounds, SEM, and observation count.
        """
        return {
            "layer": "EmissionSampling",
            "distribution": "TruncNorm(mu, SEM, a=0)",
            "mu_t_yr":   self._params.mean_annual_t,
            "sem_t_yr":  round(self._sem, 1),
            "ci95":      [self._params.ci95_lo, self._params.ci95_hi],
            "n_obs":     self._params.n_obs,
        }


class WindBiasLayer(BaseUncertaintyLayer):
    """
    Layer 2: ERA5 systematic wind bias at the annual level.

    The per-overpass +-20% random wind error is already absorbed by the
    30-observation sampling CI. This layer captures the SYSTEMATIC component:
    grid-to-point interpolation bias benchmarked at +-10% (1-sigma) per
    NIST IR 8575 Section 4.2. Modelled as a multiplicative Gaussian centred on 1.0,
    clipped to [0.5, 2.0] to prevent unphysical draws.

    References
    ----------
    NIST IR 8575 (Worden et al. 2025), Section 3.1.
    """

    CLIP_LOW  = 0.5
    CLIP_HIGH = 2.0

    def __init__(self, params: UncertaintyParams):
        """
        Parameters
        ----------
        params : UncertaintyParams
            Uncertainty configuration with wind_sigma_systematic.
        """
        self._sigma = params.wind_sigma_systematic

    def Sample(self, n_sim: int, rng: np.random.Generator) -> np.ndarray:
        """
        Draw n_sim multiplicative wind-bias factors.

        Parameters
        ----------
        n_sim : int
            Number of simulation paths.
        rng : np.random.Generator
            Seeded NumPy random generator.

        Return
        ------
        np.ndarray of shape (n_sim,) of dimensionless multipliers near 1.0.
        """
        draws = 1.0 + rng.normal(0.0, self._sigma, n_sim)
        return np.clip(draws, self.CLIP_LOW, self.CLIP_HIGH)

    def Describe(self) -> dict:
        """
        Return
        ------
        dict describing wind bias distribution parameters.
        """
        return {
            "layer":        "WindBias",
            "distribution": f"clip(1 + N(0, {self._sigma}), {self.CLIP_LOW}, {self.CLIP_HIGH})",
            "sigma":        self._sigma,
        }


class SpatialExtentLayer(BaseUncertaintyLayer):
    """
    Layer 3: Plume mask / spatial extent jitter.

    Uniform +-15% jitter on the effective plume integration area. This captures
    the sensitivity of the IME inversion to crop-window choice documented in
    report Section 6.4 and NIST IR 8575 Section 3.3 on spatial representativeness.

    References
    ----------
    Varon et al. (2021), AMT Section 2.3 spatial sensitivity tests.
    NIST IR 8575 (Worden et al. 2025), Section 3.3.
    """

    def __init__(self, params: UncertaintyParams):
        """
        Parameters
        ----------
        params : UncertaintyParams
            Uncertainty configuration with mask_jitter_lo and mask_jitter_hi.
        """
        self._lo = params.mask_jitter_lo
        self._hi = params.mask_jitter_hi

    def Sample(self, n_sim: int, rng: np.random.Generator) -> np.ndarray:
        """
        Draw n_sim uniform spatial extent multipliers.

        Parameters
        ----------
        n_sim : int
            Number of simulation paths.
        rng : np.random.Generator
            Seeded NumPy random generator.

        Return
        ------
        np.ndarray of shape (n_sim,) drawn from Uniform(lo, hi).
        """
        return rng.uniform(self._lo, self._hi, n_sim)

    def Describe(self) -> dict:
        """
        Return
        ------
        dict describing spatial extent jitter range.
        """
        return {
            "layer":        "SpatialExtent",
            "distribution": f"Uniform({self._lo}, {self._hi})",
            "range":        [self._lo, self._hi],
        }


class CarbonPriceLayer(BaseUncertaintyLayer):
    """
    Layer 5: Carbon price modelled as a log-normal (Amundi 2024 GBM approach).

    The log-normal mean is calibrated so that E[P] = central scenario price.
    Log-vol of 30% is consistent with historical EU ETS price volatility.

    References
    ----------
    Desnos, Le Guenedal, Morais & Roncalli (Amundi, 2024),
    "From Climate Stress Testing to Climate Value-at-Risk", Section 2.
    """

    def __init__(self, params: CarbonPriceParams):
        """
        Parameters
        ----------
        params : CarbonPriceParams
            Carbon price configuration with central price and log-vol.
        """
        self._central = params.central
        self._log_vol = params.log_vol
        self._mu      = np.log(params.central) - 0.5 * params.log_vol ** 2

    def Sample(self, n_sim: int, rng: np.random.Generator) -> np.ndarray:
        """
        Draw n_sim carbon price samples in EUR/tCO2e.

        Parameters
        ----------
        n_sim : int
            Number of simulation paths.
        rng : np.random.Generator
            Seeded NumPy random generator.

        Return
        ------
        np.ndarray of shape (n_sim,) in units of EUR/tCO2e.
        """
        return rng.lognormal(self._mu, self._log_vol, n_sim)

    def Describe(self) -> dict:
        """
        Return
        ------
        dict describing carbon price log-normal parameters.
        """
        return {
            "layer":        "CarbonPrice",
            "distribution": f"LogNormal(mu={self._mu:.3f}, sigma={self._log_vol})",
            "central_eur":  self._central,
            "log_vol":      self._log_vol,
        }


class RegulatoryPassThroughLayer(BaseUncertaintyLayer):
    """
    Layer 6: Regulatory enforcement pass-through modelled as a Beta distribution.

    Beta(9, 1) gives mean = 0.90, representing a conservative stress scenario where
    EU Methane Regulation enforcement is assumed highly likely. The stochastic mean
    liability therefore sits ~10% below the deterministic base case by design.

    To model a policy-uncertainty scenario (probabilistic adoption), set
    passthrough_alpha=5, passthrough_beta=2 -> mean ~0.714.

    References
    ----------
    EU Regulation 2024/1787 on methane emissions in the energy sector.
    """

    def __init__(self, params: CarbonPriceParams):
        """
        Parameters
        ----------
        params : CarbonPriceParams
            Contains passthrough_alpha and passthrough_beta for the Beta draw.
        """
        self._alpha = params.passthrough_alpha
        self._beta  = params.passthrough_beta

    def Sample(self, n_sim: int, rng: np.random.Generator) -> np.ndarray:
        """
        Draw n_sim regulatory pass-through fractions from Beta(alpha, beta).

        Parameters
        ----------
        n_sim : int
            Number of simulation paths.
        rng : np.random.Generator
            Seeded NumPy random generator.

        Return
        ------
        np.ndarray of shape (n_sim,) of fractions in [0, 1].
        """
        return rng.beta(self._alpha, self._beta, n_sim)

    def Describe(self) -> dict:
        """
        Return
        ------
        dict describing Beta distribution parameters and implied mean.
        """
        mean = self._alpha / (self._alpha + self._beta)
        return {
            "layer":        "RegulatoryPassThrough",
            "distribution": f"Beta({self._alpha}, {self._beta})",
            "mean":         round(mean, 3),
        }


# ---------------------------------------------------------------------------
# Main engine
# ---------------------------------------------------------------------------

class ClimateVarEngine:
    """
    Top-level Monte Carlo Climate Value-at-Risk engine.

    Combines all uncertainty layers (EmissionSamplingLayer, WindBiasLayer,
    SpatialExtentLayer, CarbonPriceLayer, RegulatoryPassThroughLayer) into a
    joint 10,000-path simulation and computes Climate VaR risk metrics under
    both GWP100 (EU MRV regulatory) and GWP20 (near-term transition risk) horizons.

    Typical usage
    -------------
        engine = ClimateVarEngine()
        results, liab_100, liab_20, q_annual = engine.Run()
        engine.PrintSummary(results)
        engine.SaveResults(results)

    To customise parameters, pass dataclass instances to the constructor:
        em = EmissionParams(mean_annual_t=5000.0)
        engine = ClimateVarEngine(emission_params=em)
    """

    def __init__(
        self,
        emission_params:     EmissionParams     = None,
        uncertainty_params:  UncertaintyParams  = None,
        carbon_price_params: CarbonPriceParams  = None,
    ):
        """
        Parameters
        ----------
        emission_params : EmissionParams, optional
            Observed emission record. Defaults to Belchatow 30-record dataset.
        uncertainty_params : UncertaintyParams, optional
            NIST IR 8575 uncertainty budget configuration. Defaults to documented values.
        carbon_price_params : CarbonPriceParams, optional
            Carbon price and GWP configuration. Defaults to EUR 70/tCO2e, 30% log-vol.
        """
        self._em    = emission_params    or EmissionParams()
        self._unc   = uncertainty_params or UncertaintyParams()
        self._price = carbon_price_params or CarbonPriceParams()

        self._emission_layer     = EmissionSamplingLayer(self._em)
        self._wind_layer         = WindBiasLayer(self._unc)
        self._spatial_layer      = SpatialExtentLayer(self._unc)
        self._price_layer        = CarbonPriceLayer(self._price)
        self._passthrough_layer  = RegulatoryPassThroughLayer(self._price)

    def Run(
        self, n_sim: int = DEFAULT_N_SIM, seed: int = DEFAULT_SEED
    ) -> Tuple[dict, np.ndarray, np.ndarray, np.ndarray]:
        """
        Execute the full Monte Carlo simulation.

        Parameters
        ----------
        n_sim : int
            Number of simulation paths (default 10,000).
        seed : int
            Random seed for reproducibility (default 42).

        Return
        ------
        tuple of:
            results  : dict — risk metrics, metadata, and layer descriptions.
            liab_100 : np.ndarray of shape (n_sim,) — GWP100 liability draws in M EUR.
            liab_20  : np.ndarray of shape (n_sim,) — GWP20 liability draws in M EUR.
            q_annual : np.ndarray of shape (n_sim,) — annual emission draws in t CH4/yr.
        """
        rng = np.random.default_rng(seed)

        q_base     = self._emission_layer.Sample(n_sim, rng)
        wind_mult  = self._wind_layer.Sample(n_sim, rng)
        spatial_mult = self._spatial_layer.Sample(n_sim, rng)

        if self._unc.retrieval_sigma > 0.0:
            retrieval_mult = np.clip(
                1.0 + rng.normal(0.0, self._unc.retrieval_sigma, n_sim), 0.5, 2.0
            )
        else:
            retrieval_mult = np.ones(n_sim)

        q_annual   = q_base * wind_mult * spatial_mult * retrieval_mult
        p_carbon   = self._price_layer.Sample(n_sim, rng)
        passthrough = self._passthrough_layer.Sample(n_sim, rng)

        liab_100 = q_annual * self._price.gwp100 * p_carbon * passthrough / 1e6
        liab_20  = q_annual * self._price.gwp20  * p_carbon * passthrough / 1e6

        results = {
            "metadata": {
                "n_sim":                          n_sim,
                "seed":                           seed,
                "facility":                       "KWB Belchatow Coal Mine, Poland (PGE GiEK)",
                "methodology": [
                    "Amundi 2024 — stochastic carbon price / pass-through",
                    "NIST IR 8575 (Worden et al. 2025) — IME uncertainty budget",
                ],
                "carbon_price_central_eur_tco2e": self._price.central,
                "carbon_price_log_vol":           self._price.log_vol,
                "passthrough_beta_mean":          round(
                    self._price.passthrough_alpha /
                    (self._price.passthrough_alpha + self._price.passthrough_beta), 3
                ),
                "layers": [
                    self._emission_layer.Describe(),
                    self._wind_layer.Describe(),
                    self._spatial_layer.Describe(),
                    self._price_layer.Describe(),
                    self._passthrough_layer.Describe(),
                ],
            },
            "emission_draws": {
                "q_mean_t_yr": round(float(np.mean(q_annual)),              1),
                "q_p5_t_yr":   round(float(np.percentile(q_annual,  5)),    1),
                "q_p95_t_yr":  round(float(np.percentile(q_annual, 95)),    1),
                "q_sd_t_yr":   round(float(np.std(q_annual)),               1),
            },
            "carbon_price_draws": {
                "mean_eur_tco2e": round(float(np.mean(p_carbon)),          2),
                "p5_eur_tco2e":  round(float(np.percentile(p_carbon,  5)), 2),
                "p95_eur_tco2e": round(float(np.percentile(p_carbon, 95)), 2),
            },
            "liability_gwp100": self.ComputeRiskMetrics(
                liab_100, f"GWP100 (factor {self._price.gwp100})"
            ),
            "liability_gwp20": self.ComputeRiskMetrics(
                liab_20,  f"GWP20  (factor {self._price.gwp20})"
            ),
        }
        return results, liab_100, liab_20, q_annual

    def ComputeRiskMetrics(self, liabilities: np.ndarray, label: str) -> dict:
        """
        Compute the standard Climate VaR risk metric table from a liability array.

        Parameters
        ----------
        liabilities : np.ndarray
            Array of simulated annual liability values in M EUR.
        label : str
            Human-readable label for this GWP scenario (e.g. 'GWP100 (factor 28)').

        Return
        ------
        dict with keys: label, mean, median, var_95, var_99, es_99, p5, p25, p75.
        All monetary values are in M EUR, rounded to 3 decimal places.
        """
        var99 = float(np.percentile(liabilities, 99))
        return {
            "label":   label,
            "mean":    round(float(np.mean(liabilities)),          3),
            "median":  round(float(np.median(liabilities)),        3),
            "var_95":  round(float(np.percentile(liabilities, 95)), 3),
            "var_99":  round(var99,                                 3),
            "es_99":   round(float(np.mean(liabilities[liabilities >= var99])), 3),
            "p5":      round(float(np.percentile(liabilities,  5)), 3),
            "p25":     round(float(np.percentile(liabilities, 25)), 3),
            "p75":     round(float(np.percentile(liabilities, 75)), 3),
        }

    def RunTauSensitivity(self, n_sim: int = 5_000, seed: int = 43) -> dict:
        """
        Sensitivity analysis: effect of tau bootstrap uncertainty on the lower-bound
        annualisation framing (detection-rate-weighted rather than upper-framing).

        The primary upper-framing estimate is tau-independent because it uses
        flow_rate_kgh regardless of tau classification. This method estimates the
        lower-bound framing where only DETECTION-classified records contribute.

        Parameters
        ----------
        n_sim : int
            Number of simulation paths for this sensitivity run (default 5,000).
        seed : int
            Random seed (default 43, distinct from main simulation).

        Return
        ------
        dict with tau draw statistics, detection rate, and GWP100/GWP20 liability means.
        """
        rng = np.random.default_rng(seed)
        tau_draws = np.clip(
            rng.normal(self._unc.tau_boot_mean, self._unc.tau_boot_std, n_sim),
            1.15, 6.0
        )
        scale = 0.10 / (4.34 - self._unc.tau_current)
        det_rate = np.clip(
            self._unc.base_det_rate * np.where(
                tau_draws > self._unc.tau_current,
                1.0 - scale * (tau_draws - self._unc.tau_current),
                1.0
            ),
            0.10, 1.0
        )
        q_lower = self._em.mean_flow_kgh * self._em.hours_per_year / 1e3 * det_rate
        mu_price = np.log(self._price.central) - 0.5 * self._price.log_vol ** 2
        p_carbon   = rng.lognormal(mu_price, self._price.log_vol, n_sim)
        passthrough = rng.beta(self._price.passthrough_alpha, self._price.passthrough_beta, n_sim)
        liab_100 = q_lower * self._price.gwp100 * p_carbon * passthrough / 1e6
        liab_20  = q_lower * self._price.gwp20  * p_carbon * passthrough / 1e6
        return {
            "note":                        "Lower-bound framing (det_rate x mean_flow x 8760). Upper framing is tau-independent.",
            "tau_mean_draw":               round(float(np.mean(tau_draws)),   4),
            "det_rate_mean":               round(float(np.mean(det_rate)),    3),
            "gwp100_mean_liability_meur":  round(float(np.mean(liab_100)),    3),
            "gwp20_mean_liability_meur":   round(float(np.mean(liab_20)),     3),
            "gwp100_var99_meur":           round(float(np.percentile(liab_100, 99)), 3),
            "gwp20_var99_meur":            round(float(np.percentile(liab_20,  99)), 3),
        }

    def PrintSummary(self, results: dict) -> None:
        """
        Print the Climate VaR summary table to stdout.

        Parameters
        ----------
        results : dict
            Output dict returned by Run().

        Return
        ------
        None
        """
        meta   = results["metadata"]
        gwp100 = results["liability_gwp100"]
        gwp20  = results["liability_gwp20"]
        em     = results["emission_draws"]
        price  = results["carbon_price_draws"]
        bar = "=" * 72

        print(f"\n{bar}")
        print("  CLIMATE VALUE-AT-RISK (CVaR)  |  KWB Belchatow / PGE")
        print(f"  n_sim={meta['n_sim']:,}  |  Carbon price central: "
              f"EUR {meta['carbon_price_central_eur_tco2e']}/tCO2e  "
              f"(log-vol={meta['carbon_price_log_vol']:.0%})")
        print(f"  Pass-through beta mean: {meta['passthrough_beta_mean']:.1%}")
        print(f"{bar}")
        print(f"\n  Emission draws (t CH4/yr)")
        print(f"    Mean: {em['q_mean_t_yr']:>8,.0f}   "
              f"P5: {em['q_p5_t_yr']:>8,.0f}   P95: {em['q_p95_t_yr']:>8,.0f}")
        print(f"\n  Carbon price draws (EUR/tCO2e)")
        print(f"    Mean: {price['mean_eur_tco2e']:>7.1f}   "
              f"P5: {price['p5_eur_tco2e']:>7.1f}   P95: {price['p95_eur_tco2e']:>7.1f}")
        print(f"\n{'─'*72}")
        print(f"  Annual Carbon Liability (M EUR)          GWP100        GWP20")
        print(f"{'─'*72}")
        for lbl, key in [
            ("Mean expected liability",  "mean"),
            ("Median",                   "median"),
            ("95th percentile (VaR 95)", "var_95"),
            ("99th percentile (VaR 99)", "var_99"),
            ("99% Expected Shortfall",   "es_99"),
        ]:
            print(f"  {lbl:<38}  {gwp100[key]:>8.2f}      {gwp20[key]:>8.2f}")
        ratio = gwp20["mean"] / gwp100["mean"] if gwp100["mean"] else 0
        print(f"{'─'*72}")
        print(f"  {'GWP20 / GWP100 ratio':<38}  {'—':>8}      {ratio:>7.2f}x")
        print(f"{bar}\n")

    def SaveResults(self, results: dict, path: Path = OUT_PATH) -> None:
        """
        Serialise results to JSON at the given path.

        Parameters
        ----------
        results : dict
            Output dict returned by Run() and optionally augmented with tau sensitivity.
        path : Path, optional
            Output path. Defaults to OUT_PATH (scripts/results_analysis/finance_climate_var.json).

        Return
        ------
        None
        """
        path.parent.mkdir(parents=True, exist_ok=True)
        with open(path, "w") as fh:
            json.dump(results, fh, indent=2)
        print(f"Results saved -> {path}")


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main() -> None:
    """
    Command-line entry point. Instantiates ClimateVarEngine with default parameters,
    runs the simulation, appends tau sensitivity analysis, saves JSON, and prints
    the summary table plus uncertainty decomposition.

    Return
    ------
    None
    """
    engine = ClimateVarEngine()

    print("Running Monte Carlo Climate VaR engine...")
    print(f"  n_sim={DEFAULT_N_SIM:,} | seed={DEFAULT_SEED}")

    results, liab_100, liab_20, q_annual = engine.Run(
        n_sim=DEFAULT_N_SIM, seed=DEFAULT_SEED
    )

    results["tau_sensitivity"] = engine.RunTauSensitivity(n_sim=5_000, seed=43)

    engine.SaveResults(results)
    engine.PrintSummary(results)

    # Uncertainty decomposition
    em  = engine._em
    unc = engine._unc
    t_crit = float(_T_PPF(0.975, df=em.n_obs - 1))
    sem              = (em.ci95_hi - em.ci95_lo) / (2.0 * t_crit)
    sigma_sampling   = sem / em.mean_annual_t
    sigma_wind       = unc.wind_sigma_systematic
    sigma_mask       = (unc.mask_jitter_hi - 1) / np.sqrt(3)
    sigma_price      = engine._price.log_vol
    sigma_total      = np.sqrt(sigma_sampling**2 + sigma_wind**2 +
                               sigma_mask**2 + sigma_price**2)

    print("  Uncertainty decomposition (relative sigma, independent quadrature):")
    for lbl, sig in [
        (f"Sampling CI (truncnorm, n={em.n_obs})", sigma_sampling),
        (f"Wind systematic (+-{unc.wind_sigma_systematic:.0%} ERA5)",  sigma_wind),
        ("Mask jitter (+-15% uniform)",              sigma_mask),
        (f"Carbon price (log-vol {sigma_price:.0%})", sigma_price),
    ]:
        print(f"    {lbl:<40}  {sig:.3f}  ({sig/sigma_total:.0%} of total)")
    print(f"    {'Combined sigma (quadrature)':<40}  {sigma_total:.3f}")


if __name__ == "__main__":
    main()
