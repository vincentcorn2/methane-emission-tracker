# Copernicus Data Space Ecosystem credentials
# NEVER commit this file to git. Add .env to .gitignore.
COPERNICUS_USER=your_email@columbia.edu
COPERNICUS_PASSWORD=your_password_here

# Hugging Face token for CH4Net dataset
HF_TOKEN=hf_your_token_here

# ERA5 Climate Data Store (for wind speed integration)
CDS_API_KEY=your_cds_key_here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Detection thresholds (calibrated from CH4Net paper)
# Paper default: 0.25, our optimized: 0.18
DETECTION_THRESHOLD=0.18
MIN_PLUME_PIXELS=115
