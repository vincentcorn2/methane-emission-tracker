# ── Credentials ──────────────────────────────────────────────────────────────
config/.env
*.env
.env

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# ── Model weights (too large for plain git — use download_weights.py) ─────────
# Only european_model_v8.pth is required for inference; others are experiment
# checkpoints. Upload all to cloud storage and point WEIGHTS_BASE_URL in
# download_weights.py at the hosting location.
weights/
*.pth
*.pt

# ── Raw Sentinel-2 tile cache (211 GB — re-downloadable via CDSE) ─────────────
# See README §Running the Pipeline for CDSE credentials and download commands.
data/npy_cache/

# ── TROPOMI NetCDF downloads (7.2 GB — re-downloadable from Copernicus) ───────
data/downloads/
*.nc

# ── GeoTIFF outputs (large intermediate results) ──────────────────────────────
*.tif
*.tiff
*.SAFE/
*.zip

# ── Results: exclude logs, backups, and TIF outputs; keep JSON/PNG/MD/CSV ─────
results_analysis/*.log
results_analysis/*.bak
results_analysis/*.bak2
results_analysis/*.bak_*
results_analysis/*.bugged_run
results_analysis/*.bak_pre_outlier_exclusion
results_analysis/*.bak_before_retry
# timeseries/*.bak files
results_analysis/timeseries/**/*.bak
results_analysis/timeseries/**/*.log

# ── Other large pipeline output dirs (not results_analysis) ───────────────────
results/
results_expanded/
results_survey/
results_tropomi/
results_validation/
results_bitemporal/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ── Named large run logs ──────────────────────────────────────────────────────
overnight_log.txt
results_expanded_run.log
results_multidate.log
results_multidate2.log
results_neurath_fix.log
results_validation_rerun.log

# ── Notebook execution outputs (generated by nbconvert --execute) ─────────────
*.nbconvert.ipynb

# ── Misplaced script outputs (scripts write here if ROOT is wrong; fixed) ─────
scripts/results_analysis/

# ── Generated plot written by finance script (belongs in results_analysis/) ───
scripts/finance/climate_var_distribution.png

# ── Generated documents and internal notes ────────────────────────────────────
*.docx
gemini_briefing.md
generate_report.js
generate_report_v2.js

# ── What IS tracked (small, required for reproduction) ────────────────────────
# data/crops/**              41 MB  — positive/negative/synthetic training crops
# data/nonemitter_tiles/    116 KB  — conformal calibration site tiles
# data/*.csv                ~200 KB — Climate TRACE + Carbon Mapper reference data
# results_analysis/*.json         — all pipeline output records
# results_analysis/*.png          — calibration and LOO plots
# results_analysis/*.md           — human-readable summaries
# results_analysis/*.html         — crop verification and map outputs
# figures/*.py + figures/*.png    — paper figures
